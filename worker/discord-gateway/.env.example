# Discord Gateway ワーカーの環境変数（秘密は3つだけ・DB資格情報は持たせない）
#
# Discord Developer Portal で作成した共有プラットフォームBotの Bot Token。
# Bot には「Message Content Intent」を有効化しておくこと（100サーバー未満は審査不要）。
DISCORD_BOT_TOKEN=

# app の内部 ingest エンドポイントの絶対URL。
#   例: https://<your-app-domain>/api/channels/discord/ingest
INGEST_URL=

# app 側 DISCORD_INGEST_HMAC_SECRET と同一の共有鍵（HMAC-SHA256 署名用）。
# 十分に長いランダム値にすること（例: openssl rand -hex 32）。
INGEST_HMAC_SECRET=

# 任意チューニング
# BATCH_MAX_SIZE=20
# FLUSH_INTERVAL_MS=2000
