# Supabase Configuration
# Copy this file to .env.local and fill in your values

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For server-side operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Migration適用スクリプト (scripts/apply-migration.sh) 用のDB接続文字列。
# Dashboard → Project Settings → Database → Connection string の完成URIをそのままコピー推奨
# （リージョン/ユーザー名込みで正確な値が得られる）。Transaction pooler:6543 は DDL 不可。
#
# 推奨: Session pooler（IPv4・ローカルから繋がりやすい。ホストにリージョンを含む・ユーザーは postgres.<ref>）
# SUPABASE_DB_URL=postgresql://postgres.<PROJECT-REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres?sslmode=require
#
# あるいは Direct connection（リージョン不要。ただし多くのプロジェクトで IPv6 専用）
# SUPABASE_DB_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT-REF>.supabase.co:5432/postgres?sslmode=require

# App Configuration
NEXT_PUBLIC_APP_NAME=AgentPM
# dev サーバーは port 4000 (npm run dev)。ローカルでは http://localhost:4000 を推奨
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 本番でログイン画面にデモアカウントを表示する場合のみ 'true'。通常は空
NEXT_PUBLIC_SHOW_DEMO_ACCOUNTS=

# Development Only: Demo user ID for local testing without auth
# NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000000

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=noreply@your-domain.com

# Cron secret for /api/cron/client-reminders (Bearer token, checked against
# Authorization header). pg_cron/pg_net calls this with the same value stored
# in Supabase Vault as 'cron_secret'. Generate with: openssl rand -hex 32
CRON_SECRET=

# Stripe Configuration
# Get your keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Webhook Secret (for webhook signature verification)
# Get from Stripe Dashboard > Webhooks > Your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (create products/prices in Stripe Dashboard)
# Pro Plan: https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx
# Enterprise Plan
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# System Encryption Key (for DB-stored integration secrets)
# Generate: openssl rand -hex 32
# Required only when using Admin Panel integration settings (DB storage).
# If not set, falls back to environment variables below.
SYSTEM_ENCRYPTION_KEY=

# Slack Integration
# Create your Slack App at https://api.slack.com/apps
# Required scopes: chat:write, channels:read, groups:read
# OAuth Redirect URL: https://your-domain.com/api/slack/callback
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_STATE_SECRET=your-random-secret-for-hmac
NEXT_PUBLIC_SLACK_ENABLED=false
# Internal secret for server-to-server notification calls (Portal → Notify API)
INTERNAL_NOTIFY_SECRET=your-random-internal-secret

# ============================================
# AgentPM MCP Server Configuration
# ============================================
# For Claude Code and other MCP clients to connect to AgentPM
# Generate API key from: Settings > API設定

# Your API key (generated from AgentPM settings page)
TASKAPP_API_KEY=tsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Organization ID (from URL: /{orgId}/project/...)
TASKAPP_ORG_ID=00000000-0000-0000-0000-000000000001

# Space/Project ID (from URL: /.../project/{spaceId}/...)
TASKAPP_SPACE_ID=00000000-0000-0000-0000-000000000010

# AgentPM API Base URL
TASKAPP_API_URL=http://localhost:3000/api

# Google Calendar Integration
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Required scopes: calendar.freebusy
# OAuth Redirect URL: https://your-domain.com/api/integrations/callback/google_calendar
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_STATE_SECRET=
NEXT_PUBLIC_GOOGLE_CALENDAR_ENABLED=false

# Google Meet (uses Google Calendar OAuth above)
# Requires additional scope: calendar.events
NEXT_PUBLIC_GOOGLE_MEET_ENABLED=false

# OAuth State Secret (shared across all OAuth providers)
# Recommended: migrate from GOOGLE_STATE_SECRET to this unified key
# Falls back to GOOGLE_STATE_SECRET for backward compatibility
OAUTH_STATE_SECRET=

# Zoom Integration
# Create an OAuth app at https://marketplace.zoom.us/
# For S2S: also set ZOOM_ACCOUNT_ID
# For user-level OAuth: set redirect URI below
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_REDIRECT_URI=http://localhost:3000/api/integrations/callback/zoom
NEXT_PUBLIC_ZOOM_ENABLED=false

# Microsoft Teams Integration
# Register app at https://portal.azure.com/ > App registrations
# For Client Credentials: set MS_ORGANIZER_USER_ID
# For user-level OAuth: requires OnlineMeetings.ReadWrite scope
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=
MS_REDIRECT_URI=http://localhost:3000/api/integrations/callback/teams
NEXT_PUBLIC_TEAMS_ENABLED=false
